    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Calcutta Simulation",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/calcutta_26.py",
            "console": "integratedTerminal",
            "args": [
                "--teams", "inputs/teams.csv",
                "--bracket", "inputs/bracket_2026.csv",
                "--iterations", "100000"            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}